<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Kleos Education app (Android 12+).
   Controls what data can be extracted during device-to-device transfer and cloud backup.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive authentication data from cloud backup -->
        <exclude domain="sharedpref" path="kleos_session_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive authentication data from device transfer -->
        <exclude domain="sharedpref" path="kleos_session_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>