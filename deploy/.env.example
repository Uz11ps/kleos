# Copy to deploy/.env before first start
PORT=8080
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=512

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/kleos?retryWrites=true&w=majority

# Security
JWT_SECRET=change-me-to-long-random-string

# CORS (comma-separated)
CORS_ORIGIN=https://kleos-study.ru,https://www.kleos-study.ru,https://api.kleos-study.ru
